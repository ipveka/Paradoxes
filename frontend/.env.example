# Base URL of the FastAPI backend, baked into the client at build time.
#
# Local development (backend on :8000):
NEXT_PUBLIC_API_URL=http://localhost:8000

# All-in-one Vercel deploy (API on the same domain) — use a single slash:
# NEXT_PUBLIC_API_URL=/
#
# Separate backend (e.g. Render) — the deployed API URL:
# NEXT_PUBLIC_API_URL=https://paradoxes-api.onrender.com
