# Base URL of the FastAPI backend, baked into the client at build time.
#
# Local development (backend on :8000) — copy this file to .env.local:
NEXT_PUBLIC_API_URL=http://localhost:8000

# All-in-one Vercel deploy: leave NEXT_PUBLIC_API_URL UNSET. The client then
# calls the API at a same-origin "/api/..." path, which vercel.json rewrites to
# the serverless function. No configuration needed.
#
# Separate backend (e.g. Render two-service) — set the deployed API URL:
# NEXT_PUBLIC_API_URL=https://paradoxes-api.onrender.com
